{
    "compilerOptions": {
        "module": "ESNext",
        "target": "es2022",
        "allowJs": true,
        "noImplicitAny": true,
        "moduleResolution": "bundler",
        "esModuleInterop": true,
        "allowSyntheticDefaultImports": true,
        "lib": ["es2022"],
        "types": ["node", "jest"]
    },
    "exclude": ["node_modules", "build"]
}
