{
    "name": "slides-extended",
    "version": "2.4.1",
    "description": "Create markdown-based presentations with reveal.js in Obsidian",
    "author": "Erin Schnabel",
    "license": "MIT",
    "homepage": "https://github.com/ebullient",
    "main": "src/main.ts",
    "scripts": {
        "preinstall": "npx only-allow pnpm",
        "dev": "node esbuild.config.mjs",
        "prebuild": "pnpm exec biome check ./src",
        "build": "node esbuild.config.mjs production",
        "postbuild": "pnpm run test",
        "fix": "pnpm exec biome check --write ./src",
        "format": "pnpm exec biome format ./src",
        "eslint": "pnpm exec eslint",
        "lint": "pnpm exec biome lint ./src",
        "test": "jest",
        "coverage": "jest --coverage",
        "preversion": "node esbuild.config.mjs production && pnpm run test",
        "version": "auto-changelog -p",
        "brat-notes": "run() { auto-changelog --stdout --hide-credit --hide-empty-releases --template .github/changelog.hbs -v $1 --starting-version $1  > release-notes.md; }; run"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/ebullient/obsidian-theme-ebullientworks.git"
    },
    "bugs": {
        "url": "https://github.com/ebullient/obsidian-theme-ebullientworks/issues"
    },
    "auto-changelog": {
        "backfillLimit": false,
        "commitLimit": false,
        "ignoreCommitPattern": "(🔖|👷|changelog|.* README\\.).*",
        "replaceText": {
            "([;.,] [rR]esolves) #\\d+\\.?\\s*$": "$1",
            "([;.,] [Ff]ixes) #\\d+\\.?\\s*$": "$1"
        },
        "startingDate": "2024-02-17"
    },
    "devDependencies": {
        "@biomejs/biome": "^2.4.15",
        "@types/color": "^4.2.1",
        "@types/jest": "^30.0.0",
        "@types/mustache": "^4.2.6",
        "@types/node": "^25.8.0",
        "@types/request": "^2.48.13",
        "@typescript-eslint/parser": "^8.59.4",
        "auto-changelog": "^2.6.0",
        "esbuild": "^0.28.1",
        "esbuild-plugin-copy": "^2.1.1",
        "esbuild-sass-plugin": "^3.7.0",
        "eslint": "^9.39.4",
        "eslint-plugin-obsidianmd": "^0.3.0",
        "globals": "^17.6.0",
        "jest": "^30.4.2",
        "obsidian": "^1.13.1",
        "obsidian-utilities": "^1.1.5",
        "reveal.js": "^5.2.1",
        "sass": "^1.100.0",
        "ts-jest": "^29.4.11",
        "ts-mockito": "^2.6.1",
        "ts-node": "^10.9.2",
        "tslib": "^2.8.1",
        "typescript": "^5.9.3",
        "yaml": "^2.7.1"
    },
    "dependencies": {
        "@fastify/static": "^9.1.3",
        "@progress/jszip-esm": "^1.0.4",
        "chart.js": "^4.5.1",
        "color": "^4.2.3",
        "fastify": "^5.8.5",
        "mustache": "^4.2.0"
    }
}
